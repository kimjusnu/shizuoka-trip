{
  "name": "shizuoka-trip",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "preweb": "node scripts/prepare-public-assets.js",
    "web": "expo start --web",
    "build": "node scripts/prepare-public-assets.js && npx expo export --platform web && cp -r public/* dist/ && node scripts/patch-web-html.js dist"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "expo": "~54.0.0",
    "expo-clipboard": "~8.0.8",
    "expo-font": "~14.0.11",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^0.577.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "private": true
}
